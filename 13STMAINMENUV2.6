local FirstTab = true
local function CreateTab(name)
    local TabButton = Instance.new("TextButton")
    TabButton.Size = UDim2.new(0, 160, 0, 35); TabButton.Text = "  " .. name:upper(); TabButton.Font = Enum.Font.GothamSemibold; TabButton.TextSize = 14
    TabButton.TextColor3 = FirstTab and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(150, 150, 150)
    TabButton.BackgroundColor3 = FirstTab and Color3.fromRGB(55, 25, 95) or Color3.fromRGB(28, 24, 40)
    TabButton.TextXAlignment = Enum.TextXAlignment.Left; TabButton.Parent = Sidebar
    local ButtonCorner = Instance.new("UICorner") ButtonCorner.CornerRadius = UDim.new(0, 6) ButtonCorner.Parent = TabButton

    local TabPage = Instance.new("ScrollingFrame")
    TabPage.Size = UDim2.new(1, 0, 1, 0); TabPage.BackgroundTransparency = 1; TabPage.ScrollBarThickness = 4; TabPage.ScrollBarImageColor3 = Color3.fromRGB(80, 40, 140)
    TabPage.Visible = FirstTab; TabPage.Parent = Container
    local Grid = Instance.new("UIGridLayout") Grid.CellSize = UDim2.new(0, 255, 0, 65) Grid.CellPadding = UDim2.new(0, 15, 0, 15) Grid.Parent = TabPage

    TabButton.MouseButton1Click:Connect(function()
        for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
        for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.BackgroundColor3 = Color3.fromRGB(28, 24, 40) v.TextColor3 = Color3.fromRGB(150, 150, 150) end end
        TabPage.Visible = true; TabButton.BackgroundColor3 = Color3.fromRGB(55, 25, 95); TabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    FirstTab = false; return TabPage
end

local function CreateToggle(parent, title, desc, callback)
    local ToggleFrame = Instance.new("Frame") ToggleFrame.BackgroundColor3 = Color3.fromRGB(24, 20, 36) ToggleFrame.Parent = parent
    local Corner = Instance.new("UICorner") Corner.CornerRadius = UDim.new(0, 8) Corner.Parent = ToggleFrame

    local tLabel = Instance.new("TextLabel") tLabel.Size = UDim2.new(1, -60, 0, 20) tLabel.Position = UDim2.new(0, 15, 0, 10) tLabel.Text = title tLabel.Font = Enum.Font.GothamBold; tLabel.TextSize = 13; tLabel.TextColor3 = Color3.fromRGB(240, 240, 240); tLabel.TextXAlignment = Enum.TextXAlignment.Left; tLabel.BackgroundTransparency = 1; tLabel.Parent = ToggleFrame
    local dLabel = Instance.new("TextLabel") dLabel.Size = UDim2.new(1, -60, 0, 15) dLabel.Position = UDim2.new(0, 15, 0, 30) dLabel.Text = desc dLabel.Font = Enum.Font.Gotham; dLabel.TextSize = 10; dLabel.TextColor3 = Color3.fromRGB(130, 130, 140); dLabel.TextXAlignment = Enum.TextXAlignment.Left; dLabel.BackgroundTransparency = 1; dLabel.Parent = ToggleFrame

    local Switch = Instance.new("TextButton") Switch.Size = UDim2.new(0, 40, 0, 22) Switch.Position = UDim2.new(1, -50, 0, 21) Switch.BackgroundColor3 = Color3.fromRGB(45, 40, 60) Switch.Text = ""; Switch.Parent = ToggleFrame
    local SCorner = Instance.new("UICorner") SCorner.CornerRadius = UDim.new(1, 0) SCorner.Parent = Switch
    local Circle = Instance.new("Frame") Circle.Size = UDim2.new(0, 16, 0, 16) Circle.Position = UDim2.new(0, 3, 0, 3) Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255) Circle.Parent = Switch
    local CCorner = Instance.new("UICorner") CCorner.CornerRadius = UDim.new(1, 0) CCorner.Parent = Circle

    local active = false
    Switch.MouseButton1Click:Connect(function()
        active = not active
        TweenService:Create(Circle, TweenInfo.new(0.2), {Position = active and UDim2.new(1, -19, 0, 3) or UDim2.new(0, 3, 0, 3)}):Play()
        TweenService:Create(Switch, TweenInfo.new(0.2), {BackgroundColor3 = active and Color3.fromRGB(140, 60, 255) or Color3.fromRGB(45, 40, 60)}):Play()
        pcall(callback, active)
    end)
end

local function CreateSlider(parent, title, min, max, default, callback)
    local SliderFrame = Instance.new("Frame") SliderFrame.BackgroundColor3 = Color3.fromRGB(24, 20, 36) SliderFrame.Parent = parent
    local Corner = Instance.new("UICorner") Corner.CornerRadius = UDim.new(0, 8) Corner.Parent = SliderFrame

    local tLabel = Instance.new("TextLabel") tLabel.Size = UDim2.new(1, -60, 0, 20) tLabel.Position = UDim2.new(0, 15, 0, 8) tLabel.Text = title .. " : " .. tostring(default) tLabel.Font = Enum.Font.GothamBold; tLabel.TextSize = 13; tLabel.TextColor3 = Color3.fromRGB(240, 240, 240); tLabel.TextXAlignment = Enum.TextXAlignment.Left; tLabel.BackgroundTransparency = 1; tLabel.Parent = SliderFrame

    local SlideBar = Instance.new("TextButton") SlideBar.Size = UDim2.new(1, -30, 0, 6) SlideBar.Position = UDim2.new(0, 15, 0, 40) SlideBar.BackgroundColor3 = Color3.fromRGB(45, 40, 60) SlideBar.Text = "" SlideBar.Parent = SliderFrame
    local SBCorner = Instance.new("UICorner") SBCorner.CornerRadius = UDim.new(1, 0) SBCorner.Parent = SlideBar

    local Fill = Instance.new("Frame") Fill.Size = UDim2.new((default - min)/(max - min), 0, 1, 0) Fill.BackgroundColor3 = Color3.fromRGB(140, 60, 255) Fill.BorderSizePixel = 0 Fill.Parent = SlideBar
    local FCorner = Instance.new("UICorner") FCorner.CornerRadius = UDim.new(1, 0) FCorner.Parent = Fill

    local function updateSlider(input)
        local percentage = math.clamp((input.Position.X - SlideBar.AbsolutePosition.X) / SlideBar.AbsoluteSize.X, 0, 1)
        local value = math.floor(min + (max - min) * percentage)
        tLabel.Text = title .. " : " .. tostring(value)
        Fill.Size = UDim2.new(percentage, 0, 1, 0)
        pcall(callback, value)
    end

    local sliding = false
    SlideBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = true updateSlider(input) end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then updateSlider(input) end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end
    end)
end

